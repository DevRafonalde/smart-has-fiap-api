# ─────────────────────────────────────────────────────────────
# SmartHAS — Digital 360
# Variáveis de ambiente — copie para .env e ajuste os valores
# NUNCA suba o .env real para o Git (já está no .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Perfil Spring ─────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Servidor ──────────────────────────────────────────────────
SERVER_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smarthas
DB_USER=smarthas
DB_PASSWORD=smarthas123

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ── RabbitMQ ──────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=smarthas
RABBITMQ_PASSWORD=rabbitmq123

# ── JWT ───────────────────────────────────────────────────────
# Em produção: gere com -> openssl rand -hex 64
JWT_SECRET=troque-isso-em-producao-minimo-256-bits-de-seguranca
JWT_EXPIRATION=900
JWT_REFRESH=604800

# ── Variáveis usadas também pelo docker-compose ───────────────
POSTGRES_DB=smarthas
POSTGRES_USER=smarthas
POSTGRES_PASSWORD=smarthas123

# ── E-mail (SMTP) ─────────────────────────────────────────────────────────────
# Gmail: habilite "Senhas de app" em myaccount.google.com/security
# SendGrid: use apikey como username e a chave como password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seuemail@gmail.com
MAIL_PASSWORD=sua_senha_de_app_16_caracteres
EMAIL_VERIFICACAO_EXPIRACAO=15
